<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sistema Fornitori</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <header class="app-header">
            <div class="app-title">
                <img src="~/images/Logo.png" alt="ILOG" />
                <div class="app-title-divider"></div>
                <span class="app-title-text">Sistema Import Fornitori</span>
            </div>
            <nav class="app-nav">
                <a href="/Import" class="nav-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Import" ? "active" : "")">Import file</a>
                <a href="/Catalogo" class="nav-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Catalogo" ? "active" : "")">Lista finale</a>
            </nav>
        </header>

        <main class="app-main">
            @RenderBody()
        </main>

        <footer class="app-footer">
            <span>Sistema Import Fornitori — @DateTime.Now.Year</span>
        </footer>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>